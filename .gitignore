# Per-project Spec-Kit state (created by speckit-specify at runtime) --
# this repo ships the engine, not any one project's in-progress state.
.specify/feature.json
specs/

# Machine-local Claude Code settings (permissions/paths, never shared).
# Personal overrides like defaultMode belong here, not in settings.json.
.claude/settings.local.json

# --- Standard Next.js / React ignores (kept for reference and for any app
# --- code added here). Mirrors create-next-app plus Playwright/vitest.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# testing (vitest coverage, playwright artifacts)
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example

# OS cruft
.DS_Store
Thumbs.db
*.pem
